{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "exact-hub-dev",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "export NVM_DIR=\"$HOME/.nvm\" && [ -s \"$NVM_DIR/nvm.sh\" ] && . \"$NVM_DIR/nvm.sh\" && npm run dev -- --port ${PORT:-3000}"],
      "port": 3000,
      "autoPort": true
    }
  ]
}
